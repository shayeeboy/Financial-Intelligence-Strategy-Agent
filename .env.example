# Financial-Intelligence-Strategy-Agent — environment template.
# All three upstream data sources are PUBLIC and require NO API key:
#   - Statistics Canada WDS   (https://www150.statcan.gc.ca/t1/wds/rest)
#   - CMHC (via StatCan WDS)
#   - Bank of Canada Valet API (https://www.bankofcanada.ca/valet)
#
# These optional overrides only tune client behaviour.

# HTTP request timeout in milliseconds (default 25000)
# FISA_HTTP_TIMEOUT_MS=25000

# Number of retry attempts on transient failures (default 2)
# FISA_HTTP_RETRIES=2
